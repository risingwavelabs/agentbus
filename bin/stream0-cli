#!/usr/bin/env bash
#
# stream0-cli — Simple CLI for Stream0 agent management
#
# Usage:
#   stream0-cli agent start --name NAME --description "DESC"
#   stream0-cli connect [--url URL]
#   stream0-cli status
#
set -euo pipefail

STREAM0_URL="${STREAM0_URL:-http://localhost:8080}"
STREAM0_API_KEY="${STREAM0_API_KEY:-}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MCP_CHANNEL_PATH="$(cd "$SCRIPT_DIR/../mcp" && pwd)/stream0-channel.ts"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

usage() {
    cat <<EOF
${BOLD}stream0-cli${NC} — Stream0 agent management

${BOLD}Usage:${NC}
  stream0-cli agent start --name NAME --description "DESC"
  stream0-cli connect [--url URL]
  stream0-cli status

${BOLD}Commands:${NC}
  agent start   Register an agent and launch a Claude Code worker
  connect       Connect your Claude Code to Stream0 (writes MCP config)
  status        Show Stream0 server status and registered agents

${BOLD}Environment:${NC}
  STREAM0_URL       Server URL (default: http://localhost:8080)
  STREAM0_API_KEY   API key for authentication
EOF
    exit 1
}

# HTTP helper
stream0_curl() {
    local method="$1"
    local path="$2"
    shift 2

    local curl_args=(-s -X "$method" "${STREAM0_URL}${path}" -H "Content-Type: application/json")
    if [ -n "$STREAM0_API_KEY" ]; then
        curl_args+=(-H "X-API-Key: $STREAM0_API_KEY")
    fi
    curl_args+=("$@")

    curl "${curl_args[@]}"
}

# --- agent start ---
cmd_agent_start() {
    local name=""
    local description=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name) name="$2"; shift 2 ;;
            --description) description="$2"; shift 2 ;;
            *) echo -e "${RED}Unknown option: $1${NC}"; exit 1 ;;
        esac
    done

    if [ -z "$name" ]; then
        echo -e "${RED}Error: --name is required${NC}"
        echo "Usage: stream0-cli agent start --name NAME --description \"DESC\""
        exit 1
    fi

    # Check server is running
    if ! curl -s "${STREAM0_URL}/health" > /dev/null 2>&1; then
        echo -e "${RED}Error: Stream0 server not reachable at ${STREAM0_URL}${NC}"
        echo "Start the server first: stream0 start (or ./target/release/stream0)"
        exit 1
    fi

    # Register agent
    local body="{\"id\": \"${name}\""
    if [ -n "$description" ]; then
        body+=", \"description\": \"${description}\""
    fi
    body+="}"

    local result
    result=$(stream0_curl POST /agents -d "$body")

    if echo "$result" | grep -q '"error"'; then
        echo -e "${RED}Failed to register agent: ${result}${NC}"
        exit 1
    fi

    echo -e "${GREEN}Agent \"${name}\" registered${NC}"

    # Create temporary MCP config
    local mcp_config
    mcp_config=$(mktemp -d)/mcp.json
    cat > "$mcp_config" <<MCPEOF
{
  "mcpServers": {
    "stream0-channel": {
      "command": "bun",
      "args": ["${MCP_CHANNEL_PATH}"],
      "env": {
        "STREAM0_URL": "${STREAM0_URL}",
        "STREAM0_API_KEY": "${STREAM0_API_KEY}",
        "STREAM0_AGENT_ID": "${name}"
      }
    }
  }
}
MCPEOF

    echo -e "Listening for tasks..."
    echo -e "${YELLOW}(Press Ctrl+C to stop)${NC}"
    echo ""

    # Launch Claude Code with the MCP config
    exec claude \
        --mcp-config "$mcp_config" \
        --system-prompt "You are '${name}', a worker agent on Stream0. ${description}. Wait for incoming tasks from other agents. When you receive a task via the channel, do the work using your tools, then reply with the result. Stay focused on your specialty." \
        --allowedTools "mcp__stream0-channel__reply,mcp__stream0-channel__ack,Read,Glob,Grep,Bash,Edit,Write" \
        -p "You are agent '${name}' on Stream0. ${description}. You are now online and listening for tasks. Wait for incoming messages."
}

# --- connect ---
cmd_connect() {
    local url="${STREAM0_URL}"
    local agent_id="${STREAM0_AGENT_ID:-$(whoami)-claude}"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --url) url="$2"; shift 2 ;;
            --name) agent_id="$2"; shift 2 ;;
            *) echo -e "${RED}Unknown option: $1${NC}"; exit 1 ;;
        esac
    done

    # Check server is running
    if ! curl -s "${url}/health" > /dev/null 2>&1; then
        echo -e "${RED}Error: Stream0 server not reachable at ${url}${NC}"
        echo "Start the server first."
        exit 1
    fi

    # Register self as an agent
    stream0_curl POST /agents -d "{\"id\": \"${agent_id}\"}" > /dev/null

    # Write MCP config to project .mcp.json
    local mcp_file=".mcp.json"

    # If .mcp.json exists, try to merge; otherwise create
    if [ -f "$mcp_file" ]; then
        # Check if stream0-channel already configured
        if grep -q "stream0-channel" "$mcp_file"; then
            echo -e "${YELLOW}Stream0 channel already configured in ${mcp_file}${NC}"
        else
            echo -e "${YELLOW}Warning: ${mcp_file} exists. Add this to your mcpServers manually:${NC}"
            echo ""
            cat <<SNIPPET
    "stream0-channel": {
      "command": "bun",
      "args": ["${MCP_CHANNEL_PATH}"],
      "env": {
        "STREAM0_URL": "${url}",
        "STREAM0_API_KEY": "${STREAM0_API_KEY}",
        "STREAM0_AGENT_ID": "${agent_id}"
      }
    }
SNIPPET
            echo ""
            return
        fi
    else
        cat > "$mcp_file" <<MCPEOF
{
  "mcpServers": {
    "stream0-channel": {
      "command": "bun",
      "args": ["${MCP_CHANNEL_PATH}"],
      "env": {
        "STREAM0_URL": "${url}",
        "STREAM0_API_KEY": "${STREAM0_API_KEY}",
        "STREAM0_AGENT_ID": "${agent_id}"
      }
    }
  }
}
MCPEOF
        echo -e "${GREEN}Stream0 connected to Claude Code${NC}"
        echo -e "Config written to ${mcp_file}"
    fi

    # Show available agents
    echo ""
    echo -e "${BOLD}Available agents:${NC}"
    local agents
    agents=$(stream0_curl GET /agents)
    echo "$agents" | python3 -c "
import sys, json
data = json.load(sys.stdin)
for a in data.get('agents', []):
    if a['id'] == '${agent_id}':
        continue
    desc = a.get('description') or '(no description)'
    print(f\"  - {a['id']}: {desc}\")
" 2>/dev/null || echo "  (none yet — start a worker agent first)"
}

# --- status ---
cmd_status() {
    # Check server
    local health
    health=$(curl -s "${STREAM0_URL}/health" 2>/dev/null) || {
        echo -e "${RED}Stream0 server not reachable at ${STREAM0_URL}${NC}"
        exit 1
    }

    local version
    version=$(echo "$health" | python3 -c "import sys,json; print(json.load(sys.stdin).get('version','?'))" 2>/dev/null || echo "?")
    echo -e "${GREEN}Stream0 running${NC} at ${STREAM0_URL} (${version})"
    echo ""

    # List agents
    local agents
    agents=$(stream0_curl GET /agents)
    echo -e "${BOLD}Registered agents:${NC}"
    echo "$agents" | python3 -c "
import sys, json
from datetime import datetime, timezone
data = json.load(sys.stdin)
agents = data.get('agents', [])
if not agents:
    print('  (none)')
    sys.exit()
now = datetime.now(timezone.utc)
for a in agents:
    desc = a.get('description') or '(no description)'
    ls = a.get('last_seen')
    if ls:
        try:
            seen = datetime.fromisoformat(ls.replace('Z', '+00:00'))
            diff = (now - seen).total_seconds()
            status = '● online' if diff < 300 else '○ offline'
        except:
            status = '? unknown'
    else:
        status = '○ offline'
    print(f'  {status}  {a[\"id\"]}: {desc}')
" 2>/dev/null || echo "$agents"
}

# --- Main ---
if [ $# -eq 0 ]; then
    usage
fi

case "$1" in
    agent)
        shift
        if [ $# -eq 0 ] || [ "$1" != "start" ]; then
            echo "Usage: stream0-cli agent start --name NAME --description \"DESC\""
            exit 1
        fi
        shift
        cmd_agent_start "$@"
        ;;
    connect)
        shift
        cmd_connect "$@"
        ;;
    status)
        shift
        cmd_status "$@"
        ;;
    *)
        usage
        ;;
esac
